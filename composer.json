{
    "name": "feedex/kucoin",
    "type": "library",
    "description": "KuCoin adapter package for the Feedex ecosystem.",
    "license": "MIT",
    "keywords": ["kucoin", "feedex", "crypto"],
    "autoload": {
        "psr-4": {
            "Feedex\\Kucoin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Feedex\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "feedex/feedex": "^1.0",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    }
}
